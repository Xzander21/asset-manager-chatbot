@inject EquipmentService EquipmentSvc
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Class="mr-2" />
            Confirm Delete
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (Equipment != null && (Equipment.Status == EquipmentStatus.Retired || Equipment.Status == EquipmentStatus.Decommissioned))
        {
            <MudText>Are you sure you want to delete <strong>@Equipment.Name</strong> (SN: @Equipment.SerialNumber)?</MudText>
            <MudText Class="mt-2" Color="Color.Warning">This action cannot be undone.</MudText>
        }
        else
        {
            <MudAlert Severity="Severity.Warning">
                Only equipment with status <strong>Retired</strong> or <strong>Decommissioned</strong> can be deleted.
                This equipment has status: <strong>@Equipment?.Status</strong>.
            </MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@Cancel">Cancel</MudButton>
        @if (Equipment != null && (Equipment.Status == EquipmentStatus.Retired || Equipment.Status == EquipmentStatus.Decommissioned))
        {
            <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="@DeleteAsync" Disabled="@_deleting">
                @if (_deleting)
                {
                    <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="mr-2" />
                }
                Delete
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private MudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public EquipmentDto? Equipment { get; set; }

    private bool _deleting;

    private void Cancel() => MudDialog.Cancel();

    private async Task DeleteAsync()
    {
        if (Equipment == null) return;
        _deleting = true;
        try
        {
            var (success, error) = await EquipmentSvc.DeleteAsync(Equipment.Id);
            if (success)
            {
                Snackbar.Add("Equipment deleted.", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Add($"Error: {error}", Severity.Error);
            }
        }
        finally
        {
            _deleting = false;
        }
    }
}
